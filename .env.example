# ─── Vite Client-Side Environment Variables ───────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIs...
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Supabase Edge Function Secrets ───────────────────────────────────
# Set these via: supabase secrets set KEY=VALUE
#
# RESEND_API_KEY          — Resend email service API key
# OPENAI_API_KEY          — OpenAI key for AI chat edge function
# SITE_URL                — Production URL (e.g. https://easycollect.com)
# SUPABASE_SERVICE_ROLE_KEY — Auto-injected by Supabase, no manual setup needed
# HANDYPAY_API_KEY          — HandyPay payment gateway API key
